rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsExistingDoc() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnership() {
      return ownsExistingDoc() && ownsIncomingDoc();
    }

    function hasRankedParticipants(data) {
      return data.keys().hasAll(['player1', 'player2'])
        && data.player1 is map
        && data.player2 is map
        && data.player1.keys().hasAll(['uid'])
        && data.player2.keys().hasAll(['uid']);
    }

    function isRankedParticipant(data) {
      return isSignedIn()
        && hasRankedParticipants(data)
        && (data.player1.uid == request.auth.uid || data.player2.uid == request.auth.uid);
    }

    function keepsRankedParticipants() {
      return isRankedParticipant(resource.data)
        && hasRankedParticipants(request.resource.data)
        && request.resource.data.player1.uid == resource.data.player1.uid
        && request.resource.data.player2.uid == resource.data.player2.uid;
    }

    // Users: can only read/write own doc
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // User profiles: manager name persistence
    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User settings: own doc only
    match /user_settings/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Saves: slot-based IDs (userId_slot_N) or legacy random IDs
    match /saves/{saveId} {
      allow get: if ownsExistingDoc();
      allow list: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if keepsOwnership();
      allow delete: if ownsExistingDoc();
    }
    
    // Glory saves: own saves only
    match /glory_unlocks/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /glory_saves/{saveId} {
      allow get: if ownsExistingDoc();
      allow list: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if keepsOwnership();
      allow delete: if ownsExistingDoc();
    }
    
    // Career saves: single save per user
    match /career_saves/{saveId} {
      allow get: if ownsExistingDoc();
      allow list: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if keepsOwnership();
      allow delete: if ownsExistingDoc();
    }
    
    // Contrarreloj saves: own saves only
    match /contrarreloj_saves/{saveId} {
      allow get: if ownsExistingDoc();
      allow list: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if keepsOwnership();
      allow delete: if ownsExistingDoc();
    }
    
    // ProManager saves: own saves only
    match /promanager_saves/{saveId} {
      allow get: if ownsExistingDoc();
      allow list: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if keepsOwnership();
      allow delete: if ownsExistingDoc();
    }
    
    // Editions: public read-only (game data)
    match /editions/{editionId} {
      allow read: if true;
      allow write: if false; // Admin only via Admin SDK
    }
    
    // Leagues v2: public read-only (game data, no user info)
    match /leagues_v2/{leagueId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Teams v2: public read-only (game data, no user info)
    match /teams_v2/{teamId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Metadata: public read-only (game data)
    match /metadata/{docId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Ranked: authenticated users can read public ranked data and only mutate valid participant docs.
    match /ranked_players/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
    
    match /ranked_matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isRankedParticipant(request.resource.data);
      allow update: if keepsRankedParticipants();
      allow delete: if isRankedParticipant(resource.data);
    }
    
    match /ranked_queue/{docId} {
      allow read: if isSignedIn();
      allow create: if isOwner(docId);
      allow update, delete: if isOwner(docId);
    }
    
    match /draft_matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isRankedParticipant(request.resource.data);
      allow update: if keepsRankedParticipants();
      allow delete: if isRankedParticipant(resource.data);
    }
    
    match /draft_queue/{docId} {
      allow read: if isSignedIn();
      allow create: if isOwner(docId);
      allow update, delete: if isOwner(docId);
    }
    
    // Legacy collections: public read-only
    match /leagues/{doc} { allow read: if true; allow write: if false; }
    match /teams/{doc} { allow read: if true; allow write: if false; }
    match /players/{doc} { allow read, write: if false; }
  }
}
