rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: can only read/write own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User profiles: manager name persistence
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User settings: own doc only
    match /user_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Saves: slot-based IDs (userId_slot_N) or legacy random IDs
    match /saves/{saveId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Glory saves: own saves only
    match /glory_unlocks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /glory_saves/{saveId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Career saves: single save per user
    match /career_saves/{saveId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Contrarreloj saves: own saves only
    match /contrarreloj_saves/{saveId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // ProManager saves: own saves only
    match /promanager_saves/{saveId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Editions: public read-only (game data)
    match /editions/{editionId} {
      allow read: if true;
      allow write: if false; // Admin only via Admin SDK
    }
    
    // Leagues v2: public read-only (game data, no user info)
    match /leagues_v2/{leagueId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Teams v2: public read-only (game data, no user info)
    match /teams_v2/{teamId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Metadata: public read-only (game data)
    match /metadata/{docId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Ranked: authenticated users can read/write own data
    match /ranked_players/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /ranked_matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.player1.uid == request.auth.uid
            || resource.data.player2.uid == request.auth.uid);
    }
    
    match /ranked_queue/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == docId;
      allow update, delete: if request.auth != null && request.auth.uid == docId;
    }
    
    match /draft_matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.player1.uid == request.auth.uid
            || resource.data.player2.uid == request.auth.uid);
    }
    
    match /draft_queue/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == docId;
      allow update, delete: if request.auth != null && request.auth.uid == docId;
    }
    
    // Legacy collections: public read-only
    match /leagues/{doc} { allow read: if true; allow write: if false; }
    match /teams/{doc} { allow read: if true; allow write: if false; }
    match /players/{doc} { allow read, write: if false; }
  }
}
